APP_NAME=TangKiem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error
LOG_DAILY_DAYS=7
LOG_DEPRECATIONS_CHANNEL=null

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tangkiem
DB_USERNAME=root
DB_PASSWORD=
DB_TABLE_PREFIX=tk_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Sanctum: stateful domains for SPA cookie auth (comma separated, no spaces)
# Production example: tangkiem.xyz,api.tangkiem.xyz
SANCTUM_STATEFUL_DOMAINS=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
# Use 'file' for development, 'redis' for production
CACHE_STORE=file
# CACHE_PREFIX=tk_

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (for production cache/queue)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tangkiem.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Providers
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=
ABACUS_API_KEY=
BLACKBOX_API_KEY=

# Gemini Imagen
IMAGEN_MODEL=gemini-2.5-flash-image
IMAGEN_PREDICT_MODEL=imagen-4.0-generate-001

# Curator
CURATOR_GLIDE_TOKEN=

# Playwright Server (for SPA scraping & CF bypass)
PLAYWRIGHT_SERVER_PORT=3100
PLAYWRIGHT_SERVER_URL=

# CF Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics Module
# View counts (stories/chapters) are GLOBAL across all FE domains.
# Per-site analytics data is in page_visits/daily_analytics tables (automatic).
ANALYTICS_ENABLED=true

# Exclude admin/internal IPs from analytics (comma-separated)
# Equivalent to GA's "internal traffic" filter
# IMPORTANT: Add your server IP here if Next.js SSR runs on same/nearby server
ANALYTICS_EXCLUDE_IPS=51.79.189.81

# Session dedup window (seconds). Same session+page within this window = 1 pageview.
# Prevents SSR double-counting and page refresh spam. Set to 0 to disable.
ANALYTICS_DEDUP_TTL=300

# IP Geolocation — MaxMind GeoLite2 (free, requires registration)
# Download: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Place: storage/app/geoip/GeoLite2-Country.mmdb
ANALYTICS_GEO_ENABLED=false
ANALYTICS_GEO_DATABASE=

# Google Analytics 4 (Optional — import GA4 data into daily_analytics)
# Requires: GA4 property + service account JSON key from Google Cloud Console
GA_ENABLED=false
GA_PROPERTY_ID=
GA_CREDENTIALS_PATH=
