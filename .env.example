APP_NAME=TangKiem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tangkiem
DB_USERNAME=root
DB_PASSWORD=
DB_TABLE_PREFIX=tk_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Sanctum: stateful domains for SPA cookie auth (comma separated, no spaces)
# Production example: tangkiem.xyz,api.tangkiem.xyz
SANCTUM_STATEFUL_DOMAINS=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
# Use 'file' for development, 'redis' for production
CACHE_STORE=file
# CACHE_PREFIX=tk_

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (for production cache/queue)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tangkiem.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Providers
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=
ABACUS_API_KEY=
BLACKBOX_API_KEY=

# Gemini Imagen
IMAGEN_MODEL=gemini-2.5-flash-image

# Curator
CURATOR_GLIDE_TOKEN=

# Playwright Server (for SPA scraping & CF bypass)
PLAYWRIGHT_SERVER_PORT=3100
PLAYWRIGHT_SERVER_URL=
